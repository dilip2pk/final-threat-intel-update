# =============================================================
# ThreatIntel — Docker Environment Configuration
# =============================================================
# Copy this file to .env.docker and fill in your values:
#   cp .env.docker.example .env.docker
# =============================================================

# ---- Database Provider ----
# "supabase" (default) or "postgrest" (standalone PostgreSQL mode)
VITE_DB_PROVIDER=supabase

# ---- Database ----
POSTGRES_PASSWORD=threatintel_secure_pw_change_me

# ---- JWT (used by Supabase Auth, PostgREST, Realtime) ----
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters

# ---- Supabase Anon Key ----
# Generate at: https://supabase.com/docs/guides/self-hosting#api-keys
# Or use the JWT_SECRET above to sign a JWT with role=anon
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ---- URLs ----
SITE_URL=http://localhost:8080
API_EXTERNAL_URL=http://localhost:54321
VITE_SUPABASE_URL=http://localhost:54321
VITE_LOCAL_NMAP_URL=http://localhost:3001
VITE_LOCAL_TOOLS_URL=http://localhost:3002

# ---- Functions URL (optional — auto-detected from DB_PROVIDER) ----
# Override if your edge functions / tools API is at a custom URL
# VITE_FUNCTIONS_URL=http://localhost:3002/api

# ---- Auth (optional — set to "false" to disable auth in standalone mode) ----
# VITE_AUTH_ENABLED=false

# ---- SMTP (optional — for email auth & alert notifications) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_ADMIN_EMAIL=admin@yourdomain.com

# ---- API Keys for local servers (optional) ----
NMAP_API_KEY=
TOOLS_API_KEY=

# ---- External API Keys (optional) ----
SHODAN_API_KEY=
DEFENDER_CLIENT_ID=
DEFENDER_CLIENT_SECRET=
DEFENDER_TENANT_ID=

# ---- AI (optional — for Lovable AI models) ----
LOVABLE_API_KEY=
